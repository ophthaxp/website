# Public site URL (used for canonical, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://ophthaxp.com

# Backend API base (proxied through /api/* route handlers)
API_BASE_URL=https://api.ophthaxp.com

# Nocode backend (public module endpoint) — used to fetch courses created in the admin panel
NOCODE_API_BASE_URL=http://localhost:3000
NOCODE_APP_ID=2
NOCODE_COURSES_MODULE=courses
NOCODE_DOCTORS_MODULE=doctors
# Lead capture modules (created in the admin panel as isPublic modules)
NOCODE_APPLY_LEADS_MODULE=ophthaxp_apply_leads
NOCODE_BROCHURE_LEADS_MODULE=ophthaxp_brochure_leads
# Real user id from the nocode users table; used as created_by on each lead record
NOCODE_LEADS_USER_ID=

# Hero video on the home page (override with your own trailer URL)
NEXT_PUBLIC_HERO_VIDEO_SRC=

# AI assistant (Smart Assistance section)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Newsletter / lead capture provider (optional)
LEADS_WEBHOOK_URL=
